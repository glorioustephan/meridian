{
  "name": "@meridian/cli",
  "version": "0.1.0-alpha.0",
  "description": "CLI for compiling Meridian source files to React TSX.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "meridian": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glorioustephan/meridian.git",
    "directory": "packages/cli"
  },
  "homepage": "https://glorioustephan.github.io/meridian/",
  "bugs": {
    "url": "https://github.com/glorioustephan/meridian/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm clean && tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@meridian/compiler": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
